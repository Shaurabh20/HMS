<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ShowLeaveStatus"
    android:background="@drawable/hostel3">

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/transparent_white">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name: Shaurabh Tiwari"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            android:id="@+id/name"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Days: 3"
            android:textStyle="bold"
            android:layout_alignParentRight="true"
            android:id="@+id/days"
            android:layout_marginEnd="10dp"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="From :26 May 2024"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            android:layout_below="@+id/name"
            android:layout_marginTop="10dp"
            android:id="@+id/fromDate"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To: 29 May 2024"
            android:textStyle="bold"
            android:layout_alignParentRight="true"
            android:id="@+id/toDate"
            android:layout_marginTop="10dp"
            android:layout_below="@+id/days"
            android:layout_marginEnd="10dp"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status:Denied"
            android:layout_marginStart="10dp"
            android:layout_below="@+id/fromDate"
            android:layout_marginTop="10dp"
            android:id="@+id/status"
            android:textStyle="bold"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginTop="10dp"
            android:layout_below="@id/status"/>
    </RelativeLayout>

</RelativeLayout>